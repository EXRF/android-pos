<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_sitting"
        android:layout_width="280dp"
        android:layout_height="250dp"
        android:layout_marginTop="148dp"
        android:adjustViewBounds="true"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/sitting_img" />

    <TextView
        android:id="@+id/tv_title"
        style="@style/rubik500.s16.1D2433"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp50"
        android:text="@string/app_title"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_sitting" />

    <Button
        android:id="@+id/btn_new_account"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp16"
        android:layout_marginTop="@dimen/dp30"
        android:layout_marginBottom="@dimen/dp22"
        android:backgroundTint="@color/color_1A72DD"
        android:paddingVertical="@dimen/dp18"
        android:text="@string/btn_new_account"
        android:textSize="@dimen/sp12"
        app:cornerRadius="@dimen/dp16"
        app:layout_constraintBottom_toTopOf="@+id/btn_login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp16"
        android:layout_marginBottom="@dimen/dp30"
        android:background="@drawable/rounded_outlined_shape"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/dp16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"> <!-- This centers the TextView inside the LinearLayout -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_login"
            android:textColor="@color/color_1A72DD"
            android:textSize="@dimen/sp12" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>